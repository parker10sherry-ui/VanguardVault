# =============================================================
# Vanguard Vault — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# =============================================================

# Which data provider to use on startup: "local" | "mock" | "psa" | "alt"
DATA_PROVIDER=local

# --- PSA API Credentials (server-side only) ---
# These are ONLY used by the /api/psa-cards server route.
# They are NEVER exposed to the browser.
# Option A: Direct token (if you already have one)
PSA_API_TOKEN=
# Option B: Username/password (auto-generates token)
PSA_API_BASE_URL=https://api.psacard.com/publicapi
PSA_USERNAME=
PSA_PASSWORD=

# --- Alt API Credentials (server-side only) ---
# These are ONLY used by the /api/alt-cards server route.
# They are NEVER exposed to the browser.
ALT_API_BASE_URL=
ALT_API_KEY=
ALT_API_TOKEN=

# --- Cache ---
# How long (in seconds) to cache Alt API responses server-side
ALT_CACHE_TTL_SECONDS=60
